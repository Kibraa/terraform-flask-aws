# ============================================================================
# terraform.tfvars.example — Exemple de fichier de variables
# ============================================================================
# INSTRUCTIONS :
#   1. Copier ce fichier : cp terraform.tfvars.example terraform.tfvars
#   2. Remplir les valeurs avec vos informations AWS
#   3. NE JAMAIS commiter terraform.tfvars sur Git !
# ============================================================================

# --- Credentials AWS ---
# Récupérez vos clés sur : https://console.aws.amazon.com/iam/
aws_access_key = "VOTRE_ACCESS_KEY_ICI"
aws_secret_key = "VOTRE_SECRET_KEY_ICI"
aws_region     = "eu-west-3"  # Paris

# --- Projet ---
project_name = "flask-cloud-app"
environment  = "dev"

# --- EC2 (VM) ---
instance_type       = "t2.micro"  # Free Tier eligible
key_pair_name       = "flask-app-key"
ssh_public_key_path = "~/.ssh/id_rsa.pub"

# --- S3 (Stockage) ---
# Le nom du bucket DOIT être unique au niveau mondial !
s3_bucket_name = "flask-app-static-files-VOTRE-NOM-2025"

# --- RDS (Base de données) ---
db_enabled        = true
db_engine         = "postgres"
db_instance_class = "db.t3.micro"
db_name           = "flaskdb"
db_username       = "flaskadmin"
db_password       = "UnMotDePasseTresSecurise123!"
